<%= form_for(post) do |f| %>
    <div class="field">
        <%= f.label :title%>
        <%= f.text_field :title%><br>
    </div>

    <div class="field">
        <%= f.label :header_image%>
        <%= f.file_field :header_image%><br>
    </div>

    <div class="field">
        <%= f.label :content%>
        <%= f.cktext_area :content%>
    </div>

    <div class="field">
        <%= f.label :upload %>
        <%= f.file_field :upload %><br>
    </div>

    <div class="is-primary">
        <%= f.submit "Submit!" %>
    </div>
<% end %>
