
<h1 class="title"><%= @post.title %></h1>
<h2>Authored by: <%= @post.user.username%></h2>
<p>
    <%=raw @post.content %> 
</p>

<div class="comments">
    <h3>Comments</h3>
    <%if  @post.comments.count == 0%>
    <strong>There are no comments on this post. Feel free to send one!</strong>
    <% else %>
    <% @post.comments.each do | comment |%>
        <strong><%= @comment.user.username =%> says:</strong>
        <%=raw @comment.content =%>

    <%if !user_signed_in? %>
        <strong>Yo, if you wanna comment on my site, either <%= link_to 'Sign up',  new_user_registration_path %> or <%= link_to 'Log in',  new_user_session_path %></strong>
    <% end %>

    <%if user_signed_in? %>
        <%= render partial: "comments/form", locals: {comment: @post.comments.new} %>
       
    <% end %>   
    


    



</div>
<%if current_user.role == "admin" %>
    <%= link_to 'Edit', edit_post_path(@post) %>
    <%= link_to 'Delete', @post, method: :delete %>
    <%= link_to 'Back to the main page', root_path %>

<% else %>
    <%= link_to 'Back to the main page', root_path %>
<% end %>
<% end %>